---
import '../styles/global.css';
import Navbar from '../components/ui/Navbar.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
  nav: Record<string, string>;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description,
  lang,
  nav,
  ogTitle,
  ogDescription,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <meta property="og:title"       content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString()} />
    <meta property="og:site_name"   content="Sergio Mellado" />
    <meta property="og:image"       content={new URL('/og-image.png', Astro.site ?? Astro.url).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"  content="image/png" />
    <meta property="og:image:alt"   content={ogTitle ?? title} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image"       content={new URL('/og-image.png', Astro.site ?? Astro.url).toString()} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  </head>

  <body>
    <div class="page-ambient" aria-hidden="true">
      <span class="ambient-orb ambient-orb-1"></span>
      <span class="ambient-orb ambient-orb-2"></span>
      <span class="ambient-orb ambient-orb-3"></span>
      <span class="ambient-orb ambient-orb-4"></span>
      <span class="ambient-scan"></span>
    </div>

    <Navbar currentLang={lang} nav={nav} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <span class="neon-purple">©</span>
        <span class="text-text-dim ml-2">2026</span>
        <slot name="footer-text" />
      </p>
    </footer>

    <script>
      import { initScrollReveal } from '../scripts/effects.ts';
      document.addEventListener('DOMContentLoaded', initScrollReveal);
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style>
  .page-ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .ambient-orb {
    position: absolute;
    display: block;
    border-radius: 50%;
    filter: blur(110px);
    will-change: transform;
  }

  .ambient-orb-1 {
    width: 520px;
    height: 520px;
    background: var(--color-purple-neon);
    top: 30vh;
    left: -8%;
    opacity: 0.12;
    animation: ambientDrift 38s ease-in-out infinite;
  }

  .ambient-orb-2 {
    width: 440px;
    height: 440px;
    background: var(--color-green-matrix);
    top: 55vh;
    right: -6%;
    opacity: 0.08;
    animation: ambientDrift 46s ease-in-out -14s infinite reverse;
  }

  .ambient-orb-3 {
    width: 380px;
    height: 380px;
    background: var(--color-purple-glow, var(--color-purple-neon));
    top: 85vh;
    left: 35%;
    opacity: 0.09;
    animation: ambientDrift 52s ease-in-out -22s infinite;
  }

  .ambient-orb-4 {
    width: 340px;
    height: 340px;
    background: var(--color-green-matrix);
    top: 120vh;
    left: 10%;
    opacity: 0.06;
    animation: ambientDrift 44s ease-in-out -8s infinite reverse;
  }

  @keyframes ambientDrift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(80px, -40px) scale(1.1); }
    50%      { transform: translate(-50px, 60px) scale(0.92); }
    75%      { transform: translate(40px, 30px) scale(1.05); }
  }

  .ambient-scan {
    position: absolute;
    top: 100vh;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-green-matrix), transparent);
    opacity: 0.18;
    animation: ambientScan 18s linear infinite;
  }

  @keyframes ambientScan {
    0%   { transform: translateY(0); opacity: 0; }
    10%  { opacity: 0.18; }
    90%  { opacity: 0.18; }
    100% { transform: translateY(280vh); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ambient-orb, .ambient-scan { animation: none; }
  }

  main, .site-footer {
    position: relative;
    z-index: 1;
  }

  .site-footer {
    padding: 32px 24px;
    text-align: center;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    border-top: 1px solid rgba(176, 38, 255, 0.15);
    margin-top: 40px;
  }
</style>
