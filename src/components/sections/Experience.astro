---
import SectionTitle from '../ui/SectionTitle.astro';

interface ExperienceRole {
  role: string;
  category?: string;
  dates: string;
  description?: string;
  achievements?: string[];
  stack?: string[];
}

interface ExperienceItem {
  company: string;
  url?: string;
  logos: string[];
  totalDates: string;
  location: string;
  roles: ExperienceRole[];
}

interface Props {
  data: {
    experience: {
      title: string;
      items: ExperienceItem[];
    };
  };
}
const { data } = Astro.props;
---

<section id="experience" class="py-12" aria-labelledby="experience-heading">
  <div class="wrap wrap-md text-center">
    <SectionTitle title={data.experience.title} id="experience-heading" index="02" cmd="ls -la experience/" />

    <div class="exp-stack">
      {data.experience.items.map((item) => (
        <article class="company-card reveal">
          <div class="card-header">
            <div class={`logo-row logo-row--${item.logos.length}`}>
              {item.logos.map((src) => (
                <div class="logo-box">
                  <img src={src} alt={item.company} loading="lazy" />
                </div>
              ))}
            </div>

            {item.url ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="company-name-link">
                <h3 class="company-name">{item.company}
                  <svg class="ext-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </h3>
              </a>
            ) : (
              <h3 class="company-name">{item.company}</h3>
            )}

            <span class="dates-badge font-mono text-xs">{item.totalDates}</span>
            <p class="location-text font-mono text-xs">{item.location}</p>
          </div>

          <div class="roles-list">
            {item.roles.map((r, i) => (
              <div class={`role-item${i < item.roles.length - 1 ? ' role-item--sep' : ''}`}>
                <div class="role-head">
                  {r.category && <span class="role-category">{r.category}</span>}
                  <p class="role-name">{r.role}</p>
                  {item.roles.length > 1 && (
                    <p class="role-dates font-mono text-xs neon-green">{r.dates}</p>
                  )}
                </div>

                {r.description && (
                  <p class="role-desc">{r.description}</p>
                )}

                {r.stack && r.stack.length > 0 && (
                  <ul class="role-stack" role="list">
                    {r.stack.map((tech) => (
                      <li class="stack-chip">{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-stack {
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    padding-top: 8px;
  }

  .exp-stack::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-green-matrix) 0%,
      var(--color-purple-neon) 50%,
      rgba(176, 38, 255, 0.15) 100%
    );
    transform: translateX(-50%);
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .exp-stack::before {
      left: 20px;
    }
  }

  .company-card {
    border: 1px solid rgba(176, 38, 255, 0.25);
    border-radius: 10px;
    background: var(--color-bg-secondary);
    padding: 24px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    position: relative;
    z-index: 1;
  }

  .company-card::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-bg-primary);
    border: 2px solid var(--color-green-matrix);
    transform: translateX(-50%);
    box-shadow: 0 0 12px rgba(0, 255, 65, 0.5);
    z-index: 2;
  }

  .company-card::after {
    content: '';
    position: absolute;
    top: -3px;
    left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green-matrix);
    transform: translateX(-50%);
    box-shadow: 0 0 6px var(--color-green-matrix);
    z-index: 3;
  }

  @media (max-width: 640px) {
    .company-card::before,
    .company-card::after {
      left: 20px;
    }
  }

  .company-card:hover {
    transform: translateY(-2px);
    border-color: rgba(176, 38, 255, 0.5);
    box-shadow: 0 0 20px rgba(176, 38, 255, 0.2);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(176, 38, 255, 0.15);
  }

  .logo-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .logo-box {
    width: 64px;
    height: 64px;
    padding: 6px;
    border-radius: 10px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
    transition: transform 0.2s ease;
  }

  .logo-row--3 .logo-box {
    width: 56px;
    height: 56px;
    padding: 5px;
  }

  .logo-box:hover {
    transform: translateY(-2px) scale(1.04);
  }

  .logo-box img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .company-name-link {
    text-decoration: none;
    color: inherit;
    text-shadow: none;
  }

  .company-name-link:hover {
    text-shadow: none;
    color: inherit;
  }

  .company-name {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin-top: 4px;
    transition: color 0.2s ease;
  }

  .company-name-link:hover .company-name {
    color: var(--color-green-matrix);
  }

  .ext-icon {
    opacity: 0.5;
    color: var(--color-text-dim);
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .company-name-link:hover .ext-icon {
    opacity: 1;
    color: var(--color-green-matrix);
  }

  .location-text {
    color: var(--color-text-dim);
  }

  .dates-badge {
    display: inline-block;
    padding: 4px 14px;
    border: 1px solid rgba(176, 38, 255, 0.5);
    border-radius: 9999px;
    color: var(--color-purple-neon);
    white-space: nowrap;
  }

  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: center;
  }

  .role-item {
    padding: 0 8px;
  }

  .role-item--sep {
    padding-bottom: 22px;
    margin-bottom: 22px;
    border-bottom: 1px solid rgba(176, 38, 255, 0.12);
  }

  .role-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }

  .role-category {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-green-matrix);
    background: rgba(0, 255, 65, 0.08);
    border: 1px solid rgba(0, 255, 65, 0.35);
  }

  .role-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .role-dates {
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .role-desc {
    font-size: 0.95rem;
    color: var(--color-text-dim);
    line-height: 1.75;
    max-width: 620px;
    margin: 0 auto 14px;
  }

  .role-stack {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin: 4px 0 0;
  }

  .stack-chip {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-primary);
    background: rgba(176, 38, 255, 0.1);
    border: 1px solid rgba(176, 38, 255, 0.3);
    letter-spacing: 0.02em;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .stack-chip:hover {
    border-color: var(--color-green-matrix);
    color: var(--color-green-matrix);
    background: rgba(0, 255, 65, 0.06);
  }
</style>
