---
import SectionTitle from '../ui/SectionTitle.astro';

interface AboutRow {
  icon: string;
  label: string;
  value: string;
}

interface Props {
  data: {
    about: {
      title: string;
      bio: string;
      highlight: string;
      rows: AboutRow[];
    };
  };
}
const { data } = Astro.props;

const iconMap: Record<string, string> = {
  'map-pin': `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  'graduation-cap': `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  'briefcase': `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
  'globe': `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  'cake': `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-8a2 2 0 00-2-2H6a2 2 0 00-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3M12 8v3M17 8v3"/><circle cx="7" cy="6" r="1"/><circle cx="12" cy="6" r="1"/><circle cx="17" cy="6" r="1"/></svg>`,
};
---

<section id="about" class="about-section py-12" aria-labelledby="about-heading">
  <div class="wrap wrap-lg text-center">
    <SectionTitle title={data.about.title} id="about-heading" index="01" cmd="cat about.md" />

    <div class="about-stack reveal">
      <blockquote class="about-highlight">
        {data.about.highlight}
      </blockquote>
      <p class="about-bio">
        {data.about.bio}
      </p>

      <div class="about-badges" role="list">
        {data.about.rows.map((row) => (
          <div class="about-badge" role="listitem">
            <span class="badge-icon" aria-hidden="true" set:html={iconMap[row.icon] ?? iconMap['globe']}></span>
            <div class="badge-content">
              <span class="badge-label">{row.label}</span>
              <span class="badge-value">{row.value}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .about-highlight {
    font-size: 1.25rem;
    font-style: italic;
    color: var(--color-text-primary);
    line-height: 1.6;
    max-width: 640px;
    position: relative;
    padding: 0 24px;
  }

  .about-highlight::before,
  .about-highlight::after {
    content: '"';
    color: var(--color-purple-neon);
    font-size: 2rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    line-height: 1;
    opacity: 0.5;
  }

  .about-highlight::before { margin-right: 4px; }
  .about-highlight::after { margin-left: 4px; }

  .about-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-dim);
    max-width: 620px;
    margin: 0 auto;
  }

  .about-badges {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 12px;
    width: 100%;
  }

  @media (min-width: 720px) {
    .about-badges {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .about-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: 10px;
    background: rgba(18, 0, 31, 0.55);
    border: 1px solid rgba(176, 38, 255, 0.25);
    text-align: left;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .about-badge:hover {
    border-color: var(--color-green-matrix);
    background: rgba(0, 255, 65, 0.04);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 255, 65, 0.1);
  }

  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    border-radius: 8px;
    background: rgba(176, 38, 255, 0.12);
    color: var(--color-purple-neon);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .about-badge:hover .badge-icon {
    background: rgba(0, 255, 65, 0.1);
    color: var(--color-green-matrix);
  }

  .badge-content {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .badge-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .badge-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .about-rows {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 260px));
    gap: 8px 16px;
    margin: 8px auto 0;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .about-rows {
      grid-template-columns: 1fr;
      width: 100%;
      max-width: 320px;
    }
  }

  .about-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid rgba(176, 38, 255, 0.2);
    border-radius: 6px;
    background: rgba(18, 0, 31, 0.4);
    transition: border-color 0.2s ease, background 0.2s ease;
    text-align: left;
  }

  .about-row:hover {
    border-color: var(--color-green-matrix);
    background: rgba(0, 255, 65, 0.04);
  }

  .row-icon {
    color: var(--color-purple-neon);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .row-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-primary);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .row-value {
    font-size: 0.8rem;
    color: var(--color-text-dim);
    margin-left: auto;
  }
</style>
