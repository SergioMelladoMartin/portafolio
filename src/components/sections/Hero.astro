---
import TerminalTyping from '../effects/TerminalTyping.astro';

interface Props {
  data: {
    personal: {
      name: string;
      location: string;
      email: string;
      linkedin: string;
      github: string;
      cvUrl?: string;
    };
    hero: {
      eyebrow: string;
      shortBio: string;
      statusLabel: string;
      locationShort: string;
      cvLabel?: string;
      taglines: string[];
    };
  };
}
const { data } = Astro.props;
const { hero, personal } = data;

const avatarUrl = '/avatar.png';

---

<section
  id="hero"
  class="hero-section relative"
  aria-label="Hero"
>
  <div class="hero-bg" aria-hidden="true">
    <span class="hero-orb hero-orb-1"></span>
    <span class="hero-orb hero-orb-2"></span>
    <span class="hero-orb hero-orb-3"></span>
    <span class="hero-scan"></span>
  </div>

  <div class="hero-center">

    <div class="avatar-wrap" aria-hidden="true">
      <span class="avatar-ring"></span>
      <span class="avatar-ring avatar-ring--delay"></span>
      <div class="avatar-hex">
        <div class="avatar-hex-inner">
          <img class="avatar-img" src={avatarUrl} alt={`${personal.name} avatar`} loading="eager" width="150" height="150" />
        </div>
      </div>
      <span class="avatar-badge"><span class="pulse-dot"></span></span>
    </div>

    <p class="hero-eyebrow font-mono text-sm">
      <span class="neon-green">{hero.eyebrow}</span>
    </p>

    <h1 class="hero-name font-bold text-balance">
      {personal.name}
    </h1>

    <div class="hero-typing flex justify-center items-start">
      <TerminalTyping taglines={hero.taglines} id="hero-typing" />
    </div>

    <p class="hero-bio mx-auto">
      {hero.shortBio}
    </p>

    <div class="hero-socials flex justify-center items-center gap-3">
      <a href={personal.github} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>
      <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a href={`mailto:${personal.email}`} class="social-icon" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
      {personal.cvUrl && hero.cvLabel && (
        <a href={personal.cvUrl} download class="cv-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span>{hero.cvLabel}</span>
        </a>
      )}
    </div>

    <div class="hero-meta flex flex-wrap justify-center items-center">
      <span class="hero-status flex items-center gap-2 font-mono text-xs">
        <span class="pulse-dot" aria-hidden="true"></span>
        <span class="neon-green">{hero.statusLabel}</span>
      </span>
      <span class="hero-location flex items-center gap-1 font-mono text-xs text-text-dim">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {hero.locationShort}
      </span>
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
  }

  /* ─── BACKGROUND EFFECT ─── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .hero-orb {
    position: absolute;
    display: block;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.38;
    will-change: transform;
  }

  .hero-orb-1 {
    background: var(--color-purple-neon);
    top: -120px;
    left: 6%;
    animation: orbFloat 20s ease-in-out infinite;
  }

  .hero-orb-2 {
    background: var(--color-green-matrix);
    bottom: -140px;
    right: 5%;
    opacity: 0.25;
    animation: orbFloat 26s ease-in-out -8s infinite reverse;
  }

  .hero-orb-3 {
    background: var(--color-purple-glow);
    top: 35%;
    left: 42%;
    width: 360px;
    height: 360px;
    opacity: 0.18;
    animation: orbFloat 18s ease-in-out -12s infinite;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(60px, 40px) scale(1.08); }
    66%      { transform: translate(-40px, 30px) scale(0.95); }
  }

  .hero-scan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-green-matrix), transparent);
    box-shadow: 0 0 12px var(--color-green-matrix);
    opacity: 0.6;
    animation: scanLine 8s linear infinite;
  }

  @keyframes scanLine {
    0%   { transform: translateY(0); opacity: 0; }
    8%   { opacity: 0.6; }
    92%  { opacity: 0.6; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-orb, .hero-scan { animation: none; }
  }

  /* ─── CONTENT WRAP ─── */
  .hero-center {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 48rem;
    padding: 48px 24px 56px;
    margin: 0 auto;
    gap: 16px;
  }

  /* ─── AVATAR ─── */
  .avatar-wrap {
    position: relative;
    width: 156px;
    height: 180px;
  }

  .avatar-hex {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: linear-gradient(135deg, var(--color-purple-neon) 0%, var(--color-green-matrix) 100%);
    padding: 3px;
    filter: drop-shadow(0 0 24px rgba(176, 38, 255, 0.45));
    animation: avatarGlow 4s ease-in-out infinite;
  }

  .avatar-hex-inner {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .avatar-hex-inner::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0, 255, 65, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.08) 1px, transparent 1px);
    background-size: 12px 12px;
    opacity: 0.5;
    pointer-events: none;
  }

  .avatar-img {
    position: relative;
    z-index: 1;
    width: 108%;
    height: 108%;
    object-fit: cover;
    object-position: center 20%;
    filter: drop-shadow(0 0 10px rgba(176, 38, 255, 0.35));
  }

  @keyframes avatarGlow {
    0%, 100% { filter: drop-shadow(0 0 22px rgba(176, 38, 255, 0.45)); }
    50%      { filter: drop-shadow(0 0 30px rgba(0, 255, 65, 0.55)); }
  }

  .avatar-ring {
    position: absolute;
    inset: 0;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    border: 2px solid var(--color-green-matrix);
    background: transparent;
    opacity: 0;
    animation: avatarPulse 3.2s ease-out infinite;
    pointer-events: none;
  }

  .avatar-ring--delay {
    animation-delay: 1.6s;
  }

  @keyframes avatarPulse {
    0%   { transform: scale(1); opacity: 0.55; }
    100% { transform: scale(1.45); opacity: 0; }
  }

  .avatar-badge {
    position: absolute;
    right: 8px;
    bottom: 22px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-bg-primary);
    border: 2px solid var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-badge .pulse-dot {
    width: 10px;
    height: 10px;
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-hex, .avatar-ring { animation: none; }
  }

  /* ─── TEXT ─── */
  .hero-name {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--color-text-primary);
    text-shadow: 0 0 40px rgba(176, 38, 255, 0.35);
    font-family: var(--font-sans, system-ui, sans-serif);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .hero-bio {
    color: var(--color-text-dim);
    line-height: 1.7;
    max-width: 600px;
    font-size: 1rem;
  }

  .hero-meta {
    column-gap: 72px;
    row-gap: 12px;
  }

  .hero-typing {
    min-height: 2rem;
  }

  @media (min-width: 768px) {
    .hero-typing {
      min-height: 2.5rem;
    }
  }

  .hero-typing :global(.terminal-typing-text) {
    white-space: nowrap;
  }

  .hero-location {
    color: var(--color-text-dim);
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    border: 1px solid rgba(176, 38, 255, 0.3);
    background: rgba(18, 0, 31, 0.4);
    color: var(--color-text-dim);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-icon:hover {
    border-color: var(--color-green-matrix);
    color: var(--color-green-matrix);
    background: rgba(0, 255, 65, 0.06);
    box-shadow: 0 0 12px rgba(0, 255, 65, 0.3);
    text-shadow: none;
    transform: translateY(-2px);
  }

  .cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 8px;
    border: 1px solid var(--color-purple-neon);
    background: rgba(176, 38, 255, 0.1);
    color: var(--color-purple-neon);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.2s ease;
    height: 40px;
    margin-left: 4px;
  }

  .cv-btn:hover {
    background: var(--color-purple-neon);
    color: #fff;
    box-shadow: 0 0 16px rgba(176, 38, 255, 0.5);
    text-shadow: none;
    transform: translateY(-2px);
  }
</style>
