---
import SectionTitle from '../ui/SectionTitle.astro';
import Logo from '../ui/Logo.astro';

interface CertItem {
  name: string;
  issuer: string;
  logo: string | null;
  year?: string;
  verifyUrl?: string | null;
}

interface Props {
  data: {
    certifications: {
      title: string;
      verifyLabel: string;
      items: CertItem[];
    };
  };
}
const { data } = Astro.props;

const sealIcon = `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="32" cy="28" r="16"/><path d="M24 41 L20 56 L32 50 L44 56 L40 41"/><circle cx="32" cy="28" r="10" stroke-opacity="0.5"/><path d="M27 28 L31 32 L37 24" stroke="currentColor" stroke-width="2.5"/></svg>`;
---

<section id="certifications" class="py-12" aria-labelledby="certifications-heading">
  <div class="wrap wrap-lg text-center">
    <SectionTitle title={data.certifications.title} id="certifications-heading" index="04" cmd="grep -r certified ./" />

    <div class="cert-grid">
      {data.certifications.items.map((cert) => (
        <article class="cert-card">
          <span class="cert-badge" aria-hidden="true" set:html={sealIcon}></span>

          <div class="cert-logo-wrap">
            <Logo
              src={cert.logo}
              alt={cert.issuer}
              size={44}
              fallbackInitial={cert.issuer.charAt(0)}
            />
          </div>
          <div class="cert-content">
            <h4 class="cert-name">{cert.name}</h4>
            <p class="cert-issuer">{cert.issuer}</p>
            <div class="cert-meta">
              {cert.year && <span class="cert-year">{cert.year}</span>}
              {cert.verifyUrl && (
                <a href={cert.verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-verify">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M9 12l2 2 4-4"/>
                    <circle cx="12" cy="12" r="10"/>
                  </svg>
                  {data.certifications.verifyLabel}
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cert-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  @media (min-width: 720px) {
    .cert-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cert-card {
    border: 1px solid rgba(176, 38, 255, 0.25);
    border-radius: 14px;
    background: linear-gradient(145deg, rgba(38, 20, 64, 0.9) 0%, rgba(18, 0, 31, 0.95) 100%);
    padding: 22px 22px 20px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: center;
    text-align: left;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .cert-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, var(--color-purple-neon), var(--color-green-matrix));
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .cert-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-green-matrix);
    box-shadow: 0 10px 32px rgba(0, 255, 65, 0.12);
  }

  .cert-card:hover::before {
    opacity: 1;
  }

  .cert-badge {
    position: absolute;
    top: 10px;
    right: 12px;
    width: 34px;
    height: 34px;
    color: var(--color-green-matrix);
    opacity: 0.35;
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  .cert-badge svg {
    width: 100%;
    height: 100%;
  }

  .cert-card:hover .cert-badge {
    opacity: 0.9;
    transform: scale(1.08);
  }

  .cert-logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(176, 38, 255, 0.4);
    padding: 8px;
    flex-shrink: 0;
  }

  .cert-content {
    min-width: 0;
  }

  .cert-name {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
    margin: 0;
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-purple-neon);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 4px 0 10px;
  }

  .cert-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cert-year {
    display: inline-block;
    padding: 3px 10px;
    border: 1px solid rgba(0, 255, 65, 0.4);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-green-matrix);
  }

  .cert-verify {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-green-matrix);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease, text-shadow 0.2s ease;
  }

  .cert-verify:hover {
    opacity: 1;
    text-shadow: 0 0 8px var(--color-green-matrix);
  }
</style>
