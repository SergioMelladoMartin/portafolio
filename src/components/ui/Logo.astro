---
interface Props {
  src?: string | null;
  alt: string;
  size?: number;
  fallbackInitial?: string;
}

const { src, alt, size = 48, fallbackInitial = '?' } = Astro.props;
const hasSrc = src && src.trim() !== '';
---

<div class="logo-wrapper" style={`width:${size}px;height:${size}px;flex-shrink:0;`}>
  {hasSrc ? (
    <>
      <img
        src={src}
        alt={alt}
        width={size}
        height={size}
        loading="lazy"
        referrerpolicy="no-referrer"
        class="logo-img"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <div class="logo-fallback" style="display:none;" aria-hidden="true">
        <span class="logo-initial">{fallbackInitial}</span>
      </div>
    </>
  ) : (
    <div class="logo-fallback" aria-hidden="true">
      <span class="logo-initial">{fallbackInitial}</span>
    </div>
  )}
</div>

<style>
  .logo-wrapper {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
  }

  .logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .logo-fallback {
    width: 100%;
    height: 100%;
    background: rgba(176, 38, 255, 0.2);
    border: 1px solid rgba(176, 38, 255, 0.4);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-initial {
    font-family: var(--font-mono, monospace);
    font-weight: 700;
    color: var(--color-purple-neon);
    font-size: 1.1rem;
    text-transform: uppercase;
    line-height: 1;
  }
</style>
